{
	"name": "n8n-nodes-lunch-money",
	"version": "0.1.0",
	"description": "n8n community node for the Lunch Money personal finance API (v2)",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"lunch-money",
		"finance",
		"budgeting",
		"transactions"
	],
	"license": "MIT",
	"author": {
		"name": "TensE"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"lint": "eslint nodes credentials --ext .ts",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/LunchMoneyApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/LunchMoney/LunchMoney.node.js"
		]
	},
	"devDependencies": {
		"@typescript-eslint/parser": "^7.0.0",
		"eslint": "^8.56.0",
		"gulp": "^4.0.2",
		"n8n-workflow": "^1.0.0",
		"prettier": "^3.2.0",
		"typescript": "^5.3.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
